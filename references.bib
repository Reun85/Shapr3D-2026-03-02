@article{mancinelli_practical_2021,
	title = {Practical {Computation} of the {Cut} {Locus} on {Discrete} {Surfaces}},
	volume = {40},
	copyright = {© 2021 The Author(s) Computer Graphics Forum © 2021 The Eurographics Association and John Wiley \& Sons Ltd. Published by John Wiley \& Sons Ltd.},
	issn = {1467-8659},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/cgf.14372},
	doi = {10.1111/cgf.14372},
	abstract = {We present a novel method to compute the cut locus of a distance function encoded on a polygonal mesh. Our method exploits theoretical findings about the cut locus and – with a combination of analytic, geometric and topological tools – it is able to compute a topologically correct and geometrically accurate approximation of it. Our result can be either restricted to the mesh edges, or aligned with the real cut locus. Both outputs may be useful for practical applications. We also provide a convenient tool to optionally prune the weak branches of the cut locus, simplifying its structure. Our approach supersedes prior art, in that it is easier to use and also orders of magnitude faster. In fact, it depends on just one parameter, and it flawlessly operates on meshes with high genus and very high element count at interactive rates. We experiment with different datasets and methods for geodesic distance estimation. We also present applications to local and global surface parameterization.},
	language = {en},
	number = {5},
	urldate = {2024-05-19},
	journal = {Computer Graphics Forum},
	author = {Mancinelli, C. and Livesu, M. and Puppo, E.},
	year = {2021},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/cgf.14372},
	keywords = {CCS Concepts, Mesh models, • Computing methodologies → Shape analysis, • Mathematics of computing → Continuous functions},
	pages = {261--273},
}

